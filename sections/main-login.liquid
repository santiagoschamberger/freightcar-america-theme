{{ 'customer.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- if section.settings.enable_shop_login_button == false -%}
  {%- assign hide_shop_login_button = true -%}
{%- endif -%}

<div class="customer login section-{{ section.id }}-padding">
  <h1 id="recover" tabindex="-1">
    {{ 'customer.recover_password.title' | t }}
  </h1>

  <div>
    <p>
      {{ 'customer.recover_password.subtext' | t }}
    </p>

    {%- form 'recover_customer_password' -%}
      {% assign recover_success = form.posted_successfully? %}

      <div class="field">
        <input
          type="email"
          value=""
          name="email"
          id="RecoverEmail"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          {% if form.errors %}
            aria-invalid="true"
            aria-describedby="RecoverEmail-email-error"
            autofocus
          {% endif %}
          placeholder="{{ 'customer.login_page.email' | t }}"
        >
        <label for="RecoverEmail">
          {{ 'customer.login_page.email' | t }}
        </label>
      </div>

      {%- if form.errors -%}
        <small id="RecoverEmail-email-error" class="form__message">
          <span class="svg-wrapper">
            {{- 'icon-error.svg' | inline_asset_content -}}
          </span>
          {{ form.errors.messages.form }}
        </small>
      {%- endif -%}

      {% comment %}
        this was replaced by Diane
        <button>
      {% endcomment %}

      <button type="submit">
        {{ 'customer.login_page.submit' | t }}
      </button>

      <a href="#login">
        {{ 'customer.login_page.cancel' | t }}
      </a>
    {%- endform -%}
  </div>

  <h1 id="login" tabindex="-1">
    {{ 'customer.login_page.title' | t }}
  </h1>

  <div>
    {%- if recover_success == true -%}
      <h3 class="form__message" tabindex="-1" autofocus>
        <span class="svg-wrapper">
          {{- 'icon-success.svg' | inline_asset_content -}}
        </span>
        {{ 'customer.recover_password.success' | t }}
      </h3>
    {%- endif -%}

    {%- form 'customer_login', novalidate: 'novalidate' -%}
      {%- if form.errors -%}
        <h2 class="form__message" tabindex="-1" autofocus>
          <span class="visually-hidden">{{ 'accessibility.error' | t }} </span>
          <span class="svg-wrapper">
            {{- 'icon-error.svg' | inline_asset_content -}}
          </span>
          {{ 'templates.contact.form.error_heading' | t }}
        </h2>
        {{ form.errors | default_errors }}
      {%- endif -%}

      {%- if shop.features.login_with_shop_classic_customer_accounts? -%}
        <section name="sign-in-with-shop-provider">
          {{ shop | login_button: hide_button: hide_shop_login_button }}

          {%- unless hide_shop_login_button -%}
            <p>
              {{ 'customer.login_page.alternate_provider_separator' | t }}
            </p>
          {%- endunless -%}
        </section>
      {%- endif -%}

      <div class="field">
        <input
          type="email"
          name="customer[email]"
          id="CustomerEmail"
          autocomplete="username"
          autocorrect="off"
          autocapitalize="off"
          {% if form.errors contains 'form' %}
            aria-invalid="true"
          {% endif %}
          placeholder="{{ 'customer.login_page.email' | t }}"
        >
        <label for="CustomerEmail">
          {{ 'customer.login_page.email' | t }}
        </label>
      </div>

      {%- if form.password_needed -%}
        <div class="field">
          <input
            type="password"
            value=""
            name="customer[password]"
            id="CustomerPassword"
            autocomplete="current-password"
            {% if form.errors contains 'form' %}
              aria-invalid="true"
            {% endif %}
            placeholder="{{ 'customer.login_page.password' | t }}"
          >
          <label for="CustomerPassword">
            {{ 'customer.login_page.password' | t }}
          </label>
        </div>

        <a href="#recover">
          {{ 'customer.login_page.forgot_password' | t }}
        </a>
      {%- endif -%}

      {% comment %}
        this was replaced by Diane
        <button>
      {% endcomment %}

      <button type="submit" id="CustomerLoginSubmit">
        {{ 'customer.login_page.sign_in' | t }}
      </button>
    {%- endform -%}
  </div>
</div>

{% comment %}
  Login autofill double-click fix - v2

  Root cause being targeted: in Edge/Chromium, autofilled credential fields
  can remain in a state where the browser does not treat them as "interacted
  with" until the user's first real (trusted) gesture on the page. That first
  click can get consumed by the browser unlocking/validating the autofilled
  fields instead of being delivered as a normal form submit, which is what
  produces the "click sign in twice" behavior.

  Synthetic events (dispatchEvent) do NOT fix this, because the browser
  only honors isTrusted: true gestures for this purpose.

  Strategy: listen for the FIRST trusted pointerdown/mousedown on the submit
  button. On that trusted gesture, re-read the actual current values of the
  email/password inputs (which are reliably readable once the user has
  interacted with the page), and if both are non-empty, programmatically
  submit the form ourselves from within that trusted event handler - instead
  of waiting for the click's default action, which is what gets lost, and
  without adding artificial delays.
{% endcomment %}

<script>
(function () {
  function getLoginForm() {
    return document.querySelector('form[action*="/account/login"], form[action*="/account"]');
  }

  function getLoginFields(form) {
    return {
      email: form ? form.querySelector('input[name="customer[email]"]') : null,
      password: form ? form.querySelector('input[name="customer[password]"]') : null
    };
  }

  function hasValues(fields) {
    var emailVal = fields.email ? fields.email.value : '';
    var passwordVal = fields.password ? fields.password.value : '';
    return emailVal.length > 0 && (fields.password ? passwordVal.length > 0 : true);
  }

  function initLoginAutofillFix() {
    var loginForm = getLoginForm();
    if (!loginForm) return;

    var fields = getLoginFields(loginForm);
    var submitButton = loginForm.querySelector('#CustomerLoginSubmit, button[type="submit"], input[type="submit"]');
    if (!submitButton) return;

    var hasSubmittedViaGesture = false;

    function onFirstTrustedGesture(event) {
      // Only act on real, browser-trusted user gestures.
      if (!event.isTrusted) return;

      // Avoid double-submitting if this fires more than once before
      // the form actually navigates away.
      if (hasSubmittedViaGesture) return;

      var currentFields = getLoginFields(loginForm);

      if (hasValues(currentFields)) {
        // Fields are populated (autofilled or typed) and this is a real
        // user gesture on the submit button: submit immediately instead
        // of waiting for the default click action, which is what can get
        // lost on the first click in some Edge/Chromium autofill states.
        hasSubmittedViaGesture = true;

        if (typeof loginForm.requestSubmit === 'function') {
          loginForm.requestSubmit(submitButton);
        } else {
          loginForm.submit();
        }
      }
      // If fields are empty, do nothing special - let the normal click/submit
      // flow proceed as it would have anyway.
    }

    // pointerdown fires before click and before any focus/blur side effects
    // from clicking the button, so we catch the gesture as early as possible.
    submitButton.addEventListener('pointerdown', onFirstTrustedGesture, true);

    // Fallback for browsers/cases where pointerdown isn't supported as expected.
    submitButton.addEventListener('mousedown', onFirstTrustedGesture, true);

    // Reset the guard if the form didn't actually navigate away (e.g. validation
    // error returned by Shopify), so a second real click still works normally.
    window.addEventListener('pageshow', function () {
      hasSubmittedViaGesture = false;
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLoginAutofillFix);
  } else {
    initLoginAutofillFix();
  }
})();
</script>

{% schema %}
{
  "name": "t:sections.main-login.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_shop_login_button",
      "label": "t:sections.main-login.shop_login_button.enable",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
