{{ 'customer.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- if section.settings.enable_shop_login_button == false -%}
  {%- assign hide_shop_login_button = true -%}
{%- endif -%}

<div class="customer login section-{{ section.id }}-padding">
  <h1 id="recover" tabindex="-1">
    {{ 'customer.recover_password.title' | t }}
  </h1>
  <div>
    <p>
      {{ 'customer.recover_password.subtext' | t }}
    </p>

    {%- form 'recover_customer_password' -%}
      {% assign recover_success = form.posted_successfully? %}
      <div class="field">
        <input
          type="email"
          value=""
          name="email"
          id="RecoverEmail"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          {% if form.errors %}
            aria-invalid="true"
            aria-describedby="RecoverEmail-email-error"
            autofocus
          {% endif %}
          placeholder="{{ 'customer.login_page.email' | t }}"
        >
        <label for="RecoverEmail">
          {{ 'customer.login_page.email' | t }}
        </label>
      </div>
      {%- if form.errors -%}
        <small id="RecoverEmail-email-error" class="form__message">
          <span class="svg-wrapper">
            {{- 'icon-error.svg' | inline_asset_content -}}
          </span>
          {{ form.errors.messages.form }}
        </small>
      {%- endif -%}

      {% comment %}
        this was replaced by Diane
        <button>
      {% endcomment %}

      <button type="submit">
        {{ 'customer.login_page.submit' | t }}
      </button>

      <a href="#login">
        {{ 'customer.login_page.cancel' | t }}
      </a>
    {%- endform -%}
  </div>

  <h1 id="login" tabindex="-1">
    {{ 'customer.login_page.title' | t }}
  </h1>
  <div>
    {%- if recover_success == true -%}
      <h3 class="form__message" tabindex="-1" autofocus>
        <span class="svg-wrapper">
          {{- 'icon-success.svg' | inline_asset_content -}}
        </span>
        {{ 'customer.recover_password.success' | t }}
      </h3>
    {%- endif -%}

    {%- form 'customer_login', novalidate: 'novalidate' -%}
      {%- if form.errors -%}
        <h2 class="form__message" tabindex="-1" autofocus>
          <span class="visually-hidden">{{ 'accessibility.error' | t }} </span>
          <span class="svg-wrapper">
            {{- 'icon-error.svg' | inline_asset_content -}}
          </span>
          {{ 'templates.contact.form.error_heading' | t }}
        </h2>
        {{ form.errors | default_errors }}
      {%- endif -%}

      {%- if shop.features.login_with_shop_classic_customer_accounts? -%}
        <section name="sign-in-with-shop-provider">
          {{ shop | login_button: hide_button: hide_shop_login_button }}

          {%- unless hide_shop_login_button -%}
            <p>
              {{ 'customer.login_page.alternate_provider_separator' | t }}
            </p>
          {%- endunless -%}
        </section>
      {%- endif -%}

      <div class="field">
        <input
          type="email"
          name="customer[email]"
          id="CustomerEmail"
          autocomplete="username"
          autocorrect="off"
          autocapitalize="off"
          {% if form.errors contains 'form' %}
            aria-invalid="true"
          {% endif %}
          placeholder="{{ 'customer.login_page.email' | t }}"
        >
        <label for="CustomerEmail">
          {{ 'customer.login_page.email' | t }}
        </label>
      </div>

      {%- if form.password_needed -%}
        <div class="field">
          <input
            type="password"
            value=""
            name="customer[password]"
            id="CustomerPassword"
            autocomplete="current-password"
            {% if form.errors contains 'form' %}
              aria-invalid="true"
            {% endif %}
            placeholder="{{ 'customer.login_page.password' | t }}"
          >
          <label for="CustomerPassword">
            {{ 'customer.login_page.password' | t }}
          </label>
        </div>

        <a href="#recover">
          {{ 'customer.login_page.forgot_password' | t }}
        </a>
      {%- endif -%}

      {% comment %}
        this was replaced by Diane
        <button>
      {% endcomment %}

      <button type="submit">
        {{ 'customer.login_page.sign_in' | t }}
      </button>
    {%- endform -%}
  </div>
</div>

{% comment %}
  Autofill login fix - updated version.

  This helps with the browser autofill issue where saved credentials may appear visually filled in,
  but the Shopify login form/theme scripts may not detect the values until the first interaction.

  The script forces the autofilled email/password fields to dispatch input/change events on:
  - page load
  - focus/blur/input/change
  - click/touch/pointer on submit
  - form submit
  - pageshow, for browser back-forward cache cases
{% endcomment %}

<script>
(function () {
  function getLoginForm() {
    return document.querySelector('form[action*="/account/login"], form[action*="/account"]');
  }

  function getLoginFields(form) {
    return {
      email: form ? form.querySelector('input[name="customer[email]"]') : null,
      password: form ? form.querySelector('input[name="customer[password]"]') : null
    };
  }

  function syncField(input) {
    if (!input) return;

    input.dispatchEvent(new Event('input', { bubbles: true }));
    input.dispatchEvent(new Event('change', { bubbles: true }));
    input.dispatchEvent(new KeyboardEvent('keyup', { bubbles: true }));
  }

  function syncAutofilledLoginFields() {
    var loginForm = getLoginForm();

    if (!loginForm) return;

    var fields = getLoginFields(loginForm);

    syncField(fields.email);
    syncField(fields.password);
  }

  function scheduleSync() {
    syncAutofilledLoginFields();

    setTimeout(syncAutofilledLoginFields, 50);
    setTimeout(syncAutofilledLoginFields, 150);
    setTimeout(syncAutofilledLoginFields, 300);
  }

  function initLoginAutofillFix() {
    var loginForm = getLoginForm();

    if (!loginForm) return;

    var fields = getLoginFields(loginForm);
    var submitButton = loginForm.querySelector('button[type="submit"], input[type="submit"]');

    [100, 300, 700, 1200, 2000, 3000].forEach(function (delay) {
      setTimeout(syncAutofilledLoginFields, delay);
    });

    [fields.email, fields.password].forEach(function (field) {
      if (!field) return;

      field.addEventListener('focus', scheduleSync, true);
      field.addEventListener('blur', scheduleSync, true);
      field.addEventListener('input', scheduleSync, true);
      field.addEventListener('change', scheduleSync, true);
    });

    if (submitButton) {
      submitButton.addEventListener('pointerdown', scheduleSync, true);
      submitButton.addEventListener('mousedown', scheduleSync, true);
      submitButton.addEventListener('touchstart', scheduleSync, true);
      submitButton.addEventListener('click', scheduleSync, true);
    }

    loginForm.addEventListener('submit', scheduleSync, true);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLoginAutofillFix);
  } else {
    initLoginAutofillFix();
  }

  window.addEventListener('pageshow', scheduleSync);
})();
</script>

{% schema %}
{
  "name": "t:sections.main-login.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_shop_login_button",
      "label": "t:sections.main-login.shop_login_button.enable",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}