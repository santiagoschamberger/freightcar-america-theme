{% comment %}
 this is the fix from May 28th, that final true makes the script run in the capture phase, meaning it fires before most other theme scripts.
  And it fixes the browser autofill issue where saved credentials may require clicking Log In twice.
  This forces autofilled values to register before the form submits.
{% endcomment %}



<script>
(function () {
  function getLoginForm() {
    return document.querySelector('form[action*="/account/login"]');
  }

  function syncAutofilledLoginFields() {
    var loginForm = getLoginForm();

    if (!loginForm) return;

    var emailInput = loginForm.querySelector('input[name="customer[email]"]');
    var passwordInput = loginForm.querySelector('input[name="customer[password]"]');

    [emailInput, passwordInput].forEach(function (input) {
      if (!input) return;

      if (input.value) {
        input.setAttribute('value', input.value);

        input.dispatchEvent(new Event('input', { bubbles: true }));
        input.dispatchEvent(new Event('change', { bubbles: true }));
        input.dispatchEvent(new KeyboardEvent('keyup', { bubbles: true }));
      }
    });
  }

  document.addEventListener('DOMContentLoaded', function () {
    var loginForm = getLoginForm();

    if (!loginForm) return;

    var submitButton = loginForm.querySelector('button[type="submit"]');

    setTimeout(syncAutofilledLoginFields, 100);
    setTimeout(syncAutofilledLoginFields, 400);
    setTimeout(syncAutofilledLoginFields, 900);
    setTimeout(syncAutofilledLoginFields, 1500);
    setTimeout(syncAutofilledLoginFields, 2500);

    if (submitButton) {
      submitButton.addEventListener('pointerdown', syncAutofilledLoginFields, true);
      submitButton.addEventListener('mousedown', syncAutofilledLoginFields, true);
      submitButton.addEventListener('touchstart', syncAutofilledLoginFields, true);
      submitButton.addEventListener('click', syncAutofilledLoginFields, true);
    }

    loginForm.addEventListener('submit', syncAutofilledLoginFields, true);
  });
})();
</script>





{% schema %}
{
  "name": "t:sections.main-login.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_shop_login_button",
      "label": "t:sections.main-login.shop_login_button.enable",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
